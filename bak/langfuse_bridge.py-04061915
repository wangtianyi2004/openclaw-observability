#!/usr/bin/env python3
from __future__ import annotations
"""
Langfuse Bridge v2.3

v2.3 改动（13 处修复）：
  - T1: 删除 REST API patch，改用 SDK update_trace() — 不再创建重复 trace
  - T2: 去掉 output 里的 full_log — 避免 UI 重复显示
  - T3: 写入 trace 级别 metadata — openclaw.channel、messageId 等
  - A1/G1/G6: 使用 session jsonl 真实时间戳 — latency 不再显示 0.00s
  - G2: 清洗 generation input — 去掉飞书 metadata 原文，只保留用户问题
  - G3: generation output 包含 tool_call 信息 — 不再显示空文本
  - G4/G8: 写入 session jsonl 的实际 cost（含 cache 费用）— 费用不再严重偏低
  - G5: 写入 Langfuse tool_calls 字段 — 工具调用过滤功能生效
  - G9: usage 统一用 delta（本轮增量）— cumulative 放 metadata
  - O1: tool span 使用真实执行时间 — 来自 toolResult.details.durationMs
  - O2: tool output 解析 JSON — 避免双重转义导致 UI 解析失败

数据流：
  1. session jsonl (watchdog) → 提取 user/assistant/turns/usage/cost → 入队
  2. OTel processed span (HTTP) → 提供 trace_id/channel/chatId → _span_cache
  3. worker → 合并数据 → 写入 Langfuse（1 trace + N observations）
"""

import os
import re
import json
import time
import uuid
import logging
import threading
import requests
from pathlib import Path
from collections import defaultdict
from datetime import datetime, timezone
from http.server import HTTPServer, BaseHTTPRequestHandler
from requests.auth import HTTPBasicAuth

# ── 配置 ──────────────────────────────────────────────────────────────────────

LANGFUSE_HOST = os.getenv("LANGFUSE_HOST", "http://localhost:3000")
PUBLIC_KEY    = os.getenv("LANGFUSE_PUBLIC_KEY", "")
SECRET_KEY    = os.getenv("LANGFUSE_SECRET_KEY", "")
BRIDGE_PORT   = int(os.getenv("BRIDGE_HTTP_PORT", "9099"))
WORKSPACE_DIR = os.getenv("OPENCLAW_WORKSPACE_DIR", "/workspaces")

_sessions_dir_env = os.getenv(
    "OPENCLAW_SESSIONS_DIR",
    os.path.expanduser("~/.openclaw/agents/main/sessions"),
)


def _expand_sessions_dirs(raw: str) -> list[Path]:
    import glob
    result = []
    for pattern in raw.split(","):
        pattern = pattern.strip()
        if not pattern:
            continue
        expanded = glob.glob(os.path.expanduser(pattern))
        if expanded:
            result.extend(Path(p) for p in expanded)
        else:
            result.append(Path(os.path.expanduser(pattern)))
    return result


SESSIONS_DIRS = _expand_sessions_dirs(_sessions_dir_env)

MAX_RETRIES      = 100
RETRY_FAST_COUNT = 10
RETRY_FAST_DELAY = 2
RETRY_SLOW_STEP  = 5


def get_retry_delay(attempt: int) -> int:
    if attempt <= RETRY_FAST_COUNT:
        return RETRY_FAST_DELAY
    return (attempt - RETRY_FAST_COUNT) * RETRY_SLOW_STEP


# ── 日志 ──────────────────────────────────────────────────────────────────────

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    datefmt="%Y-%m-%dT%H:%M:%S",
)
log = logging.getLogger("bridge")

# ── Langfuse API ──────────────────────────────────────────────────────────────

AUTH = HTTPBasicAuth(PUBLIC_KEY, SECRET_KEY)
BASE = LANGFUSE_HOST.rstrip("/")

# ── Langfuse SDK 初始化 ───────────────────────────────────────────────────────

os.environ.setdefault("LANGFUSE_PUBLIC_KEY", PUBLIC_KEY)
os.environ.setdefault("LANGFUSE_SECRET_KEY", SECRET_KEY)
os.environ.setdefault("LANGFUSE_HOST", LANGFUSE_HOST)

try:
    from langfuse import get_client as _lf_get_client
    _lf_client = _lf_get_client()
except Exception as _e:
    _lf_client = None

FEISHU_MSG_ID_RE = re.compile(r'"message_id"\s*:\s*"(om_[^"]+)"')

# ── OTel trace id 格式转换 ────────────────────────────────────────────────────


def normalize_trace_id(raw: str) -> str:
    raw = raw.strip().replace("-", "")
    if len(raw) == 32:
        return f"{raw[0:8]}-{raw[8:12]}-{raw[12:16]}-{raw[16:20]}-{raw[20:32]}"
    return raw


# ── OTel span 解析工具 ─────────────────────────────────────────────────────────


def _get_span_attr(span: dict, key: str) -> str:
    for attr in span.get("attributes", []):
        if attr.get("key") == key:
            val = attr.get("value", {})
            if "stringValue" in val:
                return val["stringValue"]
            if "intValue" in val:
                return str(val["intValue"])
            if "doubleValue" in val:
                return str(val["doubleValue"])
    return ""


def _get_span_attr_int(span: dict, key: str) -> int:
    raw = _get_span_attr(span, key)
    try:
        return int(raw)
    except Exception:
        return 0


def _parse_otel_export(body: bytes, content_type: str = "") -> list[dict]:
    if not body:
        return []
    try:
        data = json.loads(body)
    except Exception as e:
        log.error(f"[span] body 解析失败: {e}")
        return []
    resource_spans = data.get("resourceSpans", [])
    spans = []
    for resource_span in resource_spans:
        resource_attrs = {}
        for attr in resource_span.get("resource", {}).get("attributes", []):
            val = attr.get("value", {})
            resource_attrs[attr["key"]] = (
                val.get("stringValue") or val.get("intValue") or val.get("doubleValue") or ""
            )
        for scope_span in resource_span.get("scopeSpans", []):
            for span in scope_span.get("spans", []):
                span["_resource_attrs"] = resource_attrs
                spans.append(span)
    return spans


def _span_to_processed_info(span: dict) -> dict:
    trace_id = normalize_trace_id(span.get("traceId", ""))
    start_ns = int(span.get("startTimeUnixNano", 0))
    end_ns   = int(span.get("endTimeUnixNano", 0))
    start_dt = datetime.fromtimestamp(start_ns / 1e9, tz=timezone.utc)
    end_dt   = datetime.fromtimestamp(end_ns / 1e9, tz=timezone.utc) if end_ns else start_dt
    return {
        "trace_id":    trace_id,
        "timestamp":   start_dt.strftime("%Y-%m-%dT%H:%M:%S.%f")[:23] + "Z",
        "end_time":    end_dt.strftime("%Y-%m-%dT%H:%M:%S.%f")[:23] + "Z",
        "latency":     (end_dt - start_dt).total_seconds(),
        "environment": _get_span_attr(span, "langfuse.environment") or "default",
        "user_id":     (
            _get_span_attr(span, "user.id")
            or _get_span_attr(span, "openclaw.chatId").replace("user:", "")
        ),
        "channel":     _get_span_attr(span, "openclaw.channel"),
        "chat_id":     _get_span_attr(span, "openclaw.chatId"),
        "session_key": _get_span_attr(span, "openclaw.sessionKey"),
        "resource":    span.get("_resource_attrs", {}),
    }


def _span_to_usage_info(span: dict) -> dict:
    return {
        "session_id":         _get_span_attr(span, "openclaw.sessionId"),
        "model":              _get_span_attr(span, "openclaw.model") or _get_span_attr(span, "gen_ai.request.model"),
        "provider":           _get_span_attr(span, "openclaw.provider"),
        "input_tokens":       _get_span_attr_int(span, "openclaw.tokens.input"),
        "output_tokens":      _get_span_attr_int(span, "openclaw.tokens.output"),
        "cache_read_tokens":  _get_span_attr_int(span, "openclaw.tokens.cache_read"),
        "cache_write_tokens": _get_span_attr_int(span, "openclaw.tokens.cache_write"),
        "total_tokens":       _get_span_attr_int(span, "openclaw.tokens.total"),
    }


# ── Span 缓存 ──────────────────────────────────────────────────────────────────
# ★ v2.2: 只需要 processed span，usage 数据从 session jsonl 的 turns 里获取
_span_cache: dict[str, dict] = {}
_span_lock = threading.Lock()

# ★ 子 session 父子关联 map
_child_parent_map: dict[str, dict] = {}
_child_parent_lock = threading.Lock()

# ── HTTP Server ───────────────────────────────────────────────────────────────


class OtelSpanHandler(BaseHTTPRequestHandler):
    def do_POST(self):
        length       = int(self.headers.get("Content-Length", 0))
        content_type = self.headers.get("Content-Type", "")
        body         = self.rfile.read(length)
        spans        = _parse_otel_export(body, content_type)

        processed_count = 0
        usage_count = 0
        other_count = 0

        for span in spans:
            name       = span.get("name", "")
            message_id = _get_span_attr(span, "openclaw.messageId")

            if name == "openclaw.message.processed":
                if not message_id:
                    log.debug(f"[span] processed span 没有 messageId，跳过")
                    continue
                with _span_lock:
                    if message_id not in _span_cache:
                        _span_cache[message_id] = {}
                    _span_cache[message_id]["processed"] = _span_to_processed_info(span)
                processed_count += 1
                session_key = _get_span_attr(span, "openclaw.sessionKey")
                channel     = _get_span_attr(span, "openclaw.channel")
                log.info(
                    f"[span] ✅ processed: {message_id} "
                    f"channel={channel} session={session_key[:40] if session_key else 'n/a'}"
                )

            elif name == "openclaw.model.usage":
                # ★ v2.2: 不再需要 usage span，session jsonl 里有完整数据
                # 但仍然记录日志用于调试
                usage_count += 1
                session_key = _get_span_attr(span, "openclaw.sessionKey")
                model       = _get_span_attr(span, "openclaw.model")
                tokens      = _get_span_attr(span, "openclaw.tokens.total")
                log.debug(
                    f"[span] ℹ️ usage (忽略，使用 session jsonl): "
                    f"model={model} tokens={tokens} session={session_key[:40] if session_key else 'n/a'}"
                )
            else:
                other_count += 1

        if processed_count or usage_count:
            log.info(
                f"[span] batch 统计: processed={processed_count} "
                f"usage={usage_count}(忽略) other={other_count}"
            )

        self.send_response(200)
        self.end_headers()
        self.wfile.write(b"ok")

    def log_message(self, format, *args):
        pass


def start_http_server():
    server = HTTPServer(("0.0.0.0", BRIDGE_PORT), OtelSpanHandler)
    log.info(f"[http] 监听 :{BRIDGE_PORT}")
    server.serve_forever()


# ── SOUL.md prompt 元数据 ─────────────────────────────────────────────────────

_PROMPT_META_RE = re.compile(r"<!--\s*(prompt_id|prompt_name|prompt_version)\s*:\s*(.*?)\s*-->")
_prompt_meta_cache: dict[str, dict] = {}
_prompt_meta_lock = threading.Lock()


def get_prompt_meta_for_session(session_filepath: str) -> dict:
    try:
        parts = Path(session_filepath).parts
        for i, part in enumerate(parts):
            if part == "sessions" and i > 0:
                agent_name = parts[i - 1]
                break
        else:
            return {}
        with _prompt_meta_lock:
            if agent_name in _prompt_meta_cache:
                return _prompt_meta_cache[agent_name]
        soul_path = Path(WORKSPACE_DIR) / agent_name / "SOUL.md"
        if not soul_path.exists():
            return {}
        with open(soul_path, "r", encoding="utf-8") as f:
            header = f.read(500)
        meta = {m.group(1): m.group(2).strip() for m in _PROMPT_META_RE.finditer(header)}
        if meta:
            with _prompt_meta_lock:
                _prompt_meta_cache[agent_name] = meta
        return meta
    except Exception:
        return {}


# ── 多轮 generation + toolCall span 解析 ──────────────────────────────────────


def _collect_input_context(state, user_node_id: str, assistant_node_id: str) -> list[dict]:
    """沿 parentId 链收集这一轮 LLM 推理实际看到的所有历史消息。"""
    path = []
    cur = assistant_node_id
    while cur:
        body = state.id_to_body.get(cur)
        if not body:
            break
        path.append(cur)
        if cur == user_node_id:
            break
        pid = body.get("parentId")
        cur = pid

    path.reverse()

    messages = []
    for nid in path:
        body = state.id_to_body.get(nid)
        if not body:
            continue
        msg  = body.get("message", {})
        role = msg.get("role", "")

        if role == "user":
            texts = []
            for c in msg.get("content", []):
                if c.get("type") == "text":
                    text = c.get("text", "").strip()
                    text = re.sub(r"^\[\[.*?\]\]\s*", "", text)
                    if text:
                        texts.append(text)
            if texts:
                messages.append({"role": "user", "content": "\n".join(texts)})

        elif role == "assistant" and nid != assistant_node_id:
            texts = [
                c.get("text", "")
                for c in msg.get("content", [])
                if c.get("type") == "text" and c.get("text", "").strip()
            ]
            if texts:
                messages.append({"role": "assistant", "content": "\n".join(texts)})

        elif role == "toolResult":
            content = msg.get("content", [])
            result_text = next(
                (c.get("text", "") for c in content if c.get("type") == "text"), ""
            )
            tool_name = msg.get("toolName", "tool")
            if result_text:
                messages.append({
                    "role":    "tool",
                    "name":    tool_name,
                    "content": result_text[:2000],
                })

    return messages


def parse_conversation_turns(state, user_node_id: str) -> list[dict]:
    """从 user 消息节点出发，提取每一轮 assistant 推理及其工具调用。"""
    turns = []
    tool_results: dict[str, dict] = {}
    visited: set[str] = set()
    queue = list(state.children.get(user_node_id, []))

    while queue:
        cid = queue.pop(0)
        if cid in visited:
            continue
        visited.add(cid)
        body = state.id_to_body.get(cid)
        if not body:
            continue

        msg  = body.get("message", {})
        role = msg.get("role", "")

        if role == "toolResult":
            tool_call_id = msg.get("toolCallId", "")
            if tool_call_id:
                content = msg.get("content", [])
                result_text = next(
                    (c.get("text", "") for c in content if c.get("type") == "text"), ""
                )
                details   = msg.get("details", {})
                dur_ms    = details.get("durationMs", 0)
                result_ts = body.get("timestamp", "")
                span_start = ""
                if result_ts and dur_ms:
                    try:
                        from datetime import timedelta
                        dt = datetime.fromisoformat(result_ts.replace("Z", "+00:00"))
                        dt_start = dt - timedelta(milliseconds=dur_ms)
                        span_start = dt_start.strftime("%Y-%m-%dT%H:%M:%S.%f")[:23] + "Z"
                    except Exception:
                        span_start = result_ts
                child_session_id = ""
                if result_text:
                    try:
                        result_json = json.loads(result_text)
                        child_key = result_json.get("childSessionKey", "")
                        if child_key:
                            child_session_id = child_key.split(":")[-1]
                            with _child_parent_lock:
                                if child_session_id not in _child_parent_map:
                                    _child_parent_map[child_session_id] = {
                                        "parent_trace_id": "",
                                        "parent_span_id":  "",
                                        "pending": True,
                                    }
                    except Exception:
                        pass

                tool_results[tool_call_id] = {
                    "result":           result_text,
                    "duration_ms":      dur_ms,
                    "exit_code":        details.get("exitCode", 0),
                    "is_error":         msg.get("isError", False),
                    "start_time":       span_start or result_ts,
                    "end_time":         result_ts,
                    "child_session_id": child_session_id,
                }
            queue.extend(state.children.get(cid, []))

        elif role == "assistant":
            content   = msg.get("content", [])
            usage_raw = msg.get("usage", {})
            cost_raw  = usage_raw.get("cost", {})

            tool_calls_raw = [c for c in content if c.get("type") == "toolCall"]
            output_texts   = [
                c.get("text", "")
                for c in content
                if c.get("type") == "text" and c.get("text", "").strip()
            ]
            thinking_texts = [
                c.get("thinking", "") or c.get("content", "")
                for c in content
                if c.get("type") in ("thinking", "reasoning")
                and (c.get("thinking") or c.get("content", ""))
            ]

            input_context = _collect_input_context(state, user_node_id, cid)

            tool_result_ts = None
            for child_id in state.children.get(cid, []):
                child_body = state.id_to_body.get(child_id)
                if child_body and child_body.get("message", {}).get("role") == "toolResult":
                    tool_result_ts = child_body.get("timestamp", "")
                    break

            turn = {
                "msg_id":             body.get("id", ""),
                "start_time":         body.get("timestamp", ""),
                "end_time":           tool_result_ts or "",
                "timestamp":          body.get("timestamp", ""),
                "model":              msg.get("model", ""),
                "provider":           msg.get("provider", ""),
                "stop_reason":        msg.get("stopReason", ""),
                "input_tokens":       usage_raw.get("input", 0),
                "output_tokens":      usage_raw.get("output", 0),
                "cache_read_tokens":  usage_raw.get("cacheRead", 0),
                "cache_write_tokens": usage_raw.get("cacheWrite", 0),
                "total_tokens":       usage_raw.get("totalTokens", 0),
                "total_cost":         round(cost_raw.get("total", 0), 8),
                "cost_input":         round(cost_raw.get("input", 0), 8),
                "cost_output":        round(cost_raw.get("output", 0), 8),
                "cost_cache_read":    round(cost_raw.get("cacheRead", 0), 8),
                "cost_cache_write":   round(cost_raw.get("cacheWrite", 0), 8),
                "response_id":        msg.get("responseId", ""),
                "output_text":        "\n".join(output_texts),
                "thinking":           "\n\n".join(thinking_texts),
                "input_context":      input_context,
                "tool_calls": [
                    {
                        "call_id":          tc.get("id", ""),
                        "tool_name":        tc.get("name", ""),
                        "arguments":        tc.get("arguments", {}),
                        "result":           "",
                        "duration_ms":      0,
                        "exit_code":        0,
                        "is_error":         False,
                        "start_time":       "",
                        "end_time":         "",
                        "child_session_id": "",
                    }
                    for tc in tool_calls_raw
                ],
            }
            turns.append(turn)
            queue.extend(state.children.get(cid, []))

    # 把 toolResult 填回对应的 toolCall
    for turn in turns:
        for tc in turn["tool_calls"]:
            result_info = tool_results.get(tc["call_id"])
            if result_info:
                tc.update(result_info)

    # 补全 end_time
    for i, turn in enumerate(turns):
        if not turn["end_time"]:
            if i + 1 < len(turns):
                turn["end_time"] = turns[i + 1]["start_time"]

    return turns


# ── Langfuse 写入 ─────────────────────────────────────────────────────────────


def _get_tool_obs_type(tool_name: str) -> str:
    """根据工具名返回 observation type"""
    if tool_name in ("sessions_spawn", "sessions_yield", "subagents", "sessions_send"):
        return "agent"
    return "tool"


def _get_span_name(tc: dict) -> str:
    """生成 span name，exec/bash 带命令预览"""
    cmd_preview = ""
    if tc["tool_name"] in ("exec", "bash"):
        args = tc.get("arguments", {})
        raw_cmd = ""
        if isinstance(args, dict):
            raw_cmd = args.get("command", args.get("cmd", ""))
        elif isinstance(args, str):
            raw_cmd = args
        cmd_preview = raw_cmd.replace("\n", " ").strip()[:40]
    return (
        f"execute_tool {tc['tool_name']}: {cmd_preview}"
        if cmd_preview
        else f"execute_tool {tc['tool_name']}"
    )


def _parse_ts(ts_str: str):
    """把 ISO 时间字符串解析为 datetime"""
    if not ts_str:
        return None
    try:
        s = ts_str.replace("Z", "+00:00")
        return datetime.fromisoformat(s)
    except Exception:
        return None


def _ts_to_unix_ms(ts_str: str) -> int | None:
    """把 ISO 时间字符串转为 Unix 毫秒整数"""
    dt = _parse_ts(ts_str)
    if dt is None:
        return None
    return int(dt.timestamp() * 1000)


def ingest_to_langfuse(
    processed_info: dict,
    usage_info: dict,
    input_obj: dict,
    output_obj: dict,
    prompt_meta: dict,
    turns: list[dict],
    trace_name: str = "openclaw.message.processed",
    skip_trace_create: bool = False,
    parent_span_id: str = "",
) -> bool:
    if _lf_client is None:
        log.error("[ingest] Langfuse SDK 未初始化，无法写入")
        return False

    trace_id    = processed_info["trace_id"]
    start_time  = processed_info["timestamp"]
    end_time    = processed_info["end_time"]
    environment = processed_info["environment"]
    user_id     = processed_info.get("user_id", "") or input_obj.get("sender_id", "")
    session_id  = usage_info.get("session_id", "")
    model       = usage_info.get("model", "")

    # ★ T2: output 不再包含 full_log（避免 UI 重复显示）
    output_obj = dict(output_obj)
    output_obj["model"]    = model or output_obj.get("model", "")
    output_obj["provider"] = usage_info.get("provider", "") or output_obj.get("provider", "")
    output_obj.pop("full_log", None)

    raw_trace_id = trace_id.replace("-", "")

    if skip_trace_create and parent_span_id:
        root_trace_context = {
            "trace_id":       raw_trace_id,
            "parent_span_id": parent_span_id,
        }
    else:
        root_trace_context = {"trace_id": raw_trace_id}

    # ★ T3: trace 级别的 metadata
    trace_metadata = {
        "openclaw.channel":    processed_info.get("channel", ""),
        "openclaw.chatId":     processed_info.get("chat_id", ""),
        "openclaw.sessionKey": processed_info.get("session_key", ""),
        "openclaw.messageId":  input_obj.get("message_id", ""),
        "openclaw.model":      model,
        "openclaw.provider":   usage_info.get("provider", ""),
        "openclaw.sessionId":  session_id,
    }

    # ★ A1: 使用 session jsonl 的真实时间戳
    real_start = None
    real_end   = None
    if turns:
        real_start = _parse_ts(turns[0].get("start_time"))
        real_end   = _parse_ts(turns[-1].get("end_time") or turns[-1].get("start_time"))
    if not real_start:
        real_start = _parse_ts(start_time)
    if not real_end:
        real_end = _parse_ts(end_time)

    log.info(
        f"[ingest] SDK 写入 | trace={trace_id[:12]} | "
        f"turns={len(turns)} | skip_trace_create={skip_trace_create} | "
        f"userId={user_id[:16] if user_id else 'n/a'} | sessionId={session_id[:20] if session_id else 'n/a'}"
    )

    try:
        with _lf_client.start_as_current_observation(
            as_type="agent",
            name="openclaw.message.processed",
            trace_context=root_trace_context,
            input=input_obj if not skip_trace_create else None,
            output=output_obj if not skip_trace_create else None,
            metadata={
                **trace_metadata,
                "real_start_time": real_start.isoformat() if real_start else "",
                "real_end_time":   real_end.isoformat() if real_end else "",
                "real_duration_s": round((real_end - real_start).total_seconds(), 2) if real_start and real_end else 0,
            },
        ) as root_obs:
            # ★ T1: 用 ingestion API upsert 设置 userId/sessionId
            if not skip_trace_create:
                try:
                    import uuid as _uuid
                    from langfuse.api.ingestion.types import IngestionEvent_TraceCreate, TraceBody
                    _lf_client.api.ingestion.batch(batch=[
                        IngestionEvent_TraceCreate(
                            id=str(_uuid.uuid4()),
                            type="trace-create",
                            timestamp=start_time if isinstance(start_time, str) else str(start_time),
                            body=TraceBody(
                                id=raw_trace_id,
                                user_id=user_id or None,
                                session_id=session_id or None,
                                metadata=trace_metadata,
                            ),
                        )
                    ])
                except Exception as e:
                    log.warning(f"[ingest] update_trace 失败（非致命）: {e}")

            if turns:
                prev_total = 0
                for i, turn in enumerate(turns):
                    # ★ G2: 清洗 generation input，去掉飞书 metadata 原文
                    turn_input = turn.get("input_context") or input_obj
                    if isinstance(turn_input, list):
                        cleaned_input = []
                        for msg in turn_input:
                            if msg.get("role") == "user":
                                # 清洗飞书 metadata，只保留用户实际文本
                                content = msg.get("content", "")
                                content = re.sub(r"Conversation info \(untrusted metadata\):\s*```json\s*\{.*?\}\s*```\s*", "", content, flags=re.DOTALL)
                                content = re.sub(r"Sender \(untrusted metadata\):\s*```json\s*\{.*?\}\s*```\s*", "", content, flags=re.DOTALL)
                                content = re.sub(r"\[message_id:[^\]]*\]\s*", "", content)
                                content = re.sub(r"^[^:：\n]+[:：]\s*", "", content.strip())
                                cleaned_input.append({"role": "user", "content": content.strip()})
                            else:
                                cleaned_input.append(msg)
                        turn_input = cleaned_input

                    cur_total   = turn["total_tokens"]
                    delta_total = cur_total - prev_total
                    delta_in    = turn["input_tokens"]
                    delta_out   = turn["output_tokens"]
                    delta_cr    = turn["cache_read_tokens"]
                    delta_cw    = turn["cache_write_tokens"]
                    prev_total  = cur_total

                    # ★ G1/G6: 使用 session jsonl 的真实时间戳
                    gen_start = _parse_ts(turn.get("start_time")) or real_start
                    gen_end   = _parse_ts(turn.get("end_time"))   or real_end

                    # ★ G3: 优化 generation output，包含 toolCall 信息
                    gen_output = {
                        "text":        turn["output_text"],
                        "stop_reason": turn["stop_reason"],
                    }
                    if turn["tool_calls"]:
                        gen_output["tool_calls"] = [
                            {"name": tc["tool_name"], "arguments": tc["arguments"]}
                            for tc in turn["tool_calls"]
                        ]

                    # ★ G4/G8: 写入 session jsonl 的实际 cost（含 cache 费用）
                    cost_details = {}
                    if turn.get("total_cost", 0) > 0:
                        cost_details = {
                            "input":              turn.get("cost_input", 0),
                            "output":             turn.get("cost_output", 0),
                            "cache_read_tokens":  turn.get("cost_cache_read", 0),
                            "cache_write_tokens": turn.get("cost_cache_write", 0),
                            "total":              turn["total_cost"],
                        }

                    # ★ G9: usage 统一用 delta（本轮增量），cumulative 放 metadata
                    gen_usage = {
                        "input":              delta_in,
                        "output":             delta_out,
                        "cache_read_tokens":  delta_cr,
                        "cache_write_tokens": delta_cw,
                        "total":              delta_total,
                    }

                    gen_metadata = {
                        "msg_id":           turn["msg_id"],
                        "stop_reason":      turn["stop_reason"],
                        "provider":         turn["provider"],
                        "cumulative_total": cur_total,
                        "thinking":         turn.get("thinking", ""),
                        "cost_total":       turn.get("total_cost", 0),
                        "responseId":       turn.get("response_id", ""),
                    }

                    # 把真实时间放入 metadata
                    gen_metadata["real_start_time"] = gen_start.isoformat() if gen_start else ""
                    gen_metadata["real_end_time"]   = gen_end.isoformat() if gen_end else ""
                    gen_metadata["real_duration_s"] = round((gen_end - gen_start).total_seconds(), 2) if gen_start and gen_end else 0

                    with _lf_client.start_as_current_observation(
                        as_type="generation",
                        name="openclaw.model.usage",
                        model=turn["model"] or model,
                        input=turn_input,
                        output=gen_output,
                        usage_details=gen_usage,
                        cost_details=cost_details if cost_details else None,
                        metadata=gen_metadata,
                    ) as gen_obs:
                        # ★ G5: 写入 tool_calls 到 Langfuse 的 tool_calls 字段
                        if turn["tool_calls"]:
                            try:
                                gen_obs.update(
                                    tool_calls=[
                                        {"name": tc["tool_name"], "arguments": tc["arguments"], "id": tc["call_id"]}
                                        for tc in turn["tool_calls"]
                                    ]
                                )
                            except Exception as e:
                                log.debug(f"[ingest] 设置 tool_calls 失败: {e}")

                        for tc in turn["tool_calls"]:
                            span_name  = _get_span_name(tc)
                            obs_type   = _get_tool_obs_type(tc["tool_name"])

                            # ★ O1: 使用 session jsonl 的真实工具执行时间
                            span_start = _parse_ts(tc.get("start_time")) or gen_start
                            span_end   = _parse_ts(tc.get("end_time"))   or gen_end

                            span_meta = {
                                "tool_call_id": tc["call_id"],
                                "tool_name":    tc["tool_name"],
                                "exit_code":    tc["exit_code"],
                                "duration_ms":  tc["duration_ms"],
                                "is_error":     tc["is_error"],
                            }
                            if tc.get("child_session_id"):
                                span_meta["child_trace_id"] = tc["child_session_id"]

                            # ★ O2: tool output 保持完整，确保 JSON 有效
                            tool_output = tc["result"]
                            try:
                                # 如果 result 是有效 JSON 字符串，解析后写入（避免双重转义）
                                parsed = json.loads(tool_output)
                                tool_output_obj = {"result": parsed}
                            except (json.JSONDecodeError, TypeError):
                                tool_output_obj = {"result": tool_output}

                            # 把真实时间放入 metadata
                            span_meta["real_start_time"] = span_start.isoformat() if span_start else ""
                            span_meta["real_end_time"]   = span_end.isoformat() if span_end else ""
                            span_meta["real_duration_s"] = round((span_end - span_start).total_seconds(), 2) if span_start and span_end else 0

                            with _lf_client.start_as_current_observation(
                                as_type=obs_type,
                                name=span_name,
                                input=tc["arguments"],
                                output=tool_output_obj,
                                metadata=span_meta,
                                level="ERROR" if tc["is_error"] else "DEFAULT",
                            ) as span_obs:
                                if tc.get("child_session_id"):
                                    span_id = _lf_client.get_current_observation_id()
                                    with _child_parent_lock:
                                        _child_parent_map[tc["child_session_id"]] = {
                                            "parent_trace_id": trace_id,
                                            "parent_span_id":  span_id or "",
                                            "pending": False,
                                        }
                                    log.info(f"  [child_map] {tc['child_session_id'][:8]} -> trace={trace_id[:8]} span={str(span_id or '')[:8]}")

                            log.info(
                                f"  [tool] {span_name} "
                                f"exit={tc['exit_code']} dur={tc['duration_ms']}ms"
                            )
            else:
                with _lf_client.start_as_current_observation(
                    as_type="generation",
                    name="openclaw.model.usage",
                    model=model,
                    input=input_obj,
                    output=output_obj,
                    usage_details={
                        "input":              usage_info["input_tokens"],
                        "output":             usage_info["output_tokens"],
                        "cache_read_tokens":  usage_info["cache_read_tokens"],
                        "cache_write_tokens": usage_info["cache_write_tokens"],
                        "total":              usage_info["total_tokens"],
                    },
                ):
                    pass

        _lf_client.flush()
        time.sleep(0.5)

        # ★ T1: 删除 REST API patch — 不再创建重复 trace

        log.info(f"✅ 写入成功: trace={trace_id[:12]} session={session_id[:12] if session_id else 'n/a'} model={model}")
        return True

    except Exception as e:
        log.error(f"[ingest] ❌ SDK 写入失败: {e}", exc_info=True)
        return False


# ── 增量读取状态 ──────────────────────────────────────────────────────────────


class FileState:
    def __init__(self):
        self.offset: int = 0
        self.size: int = 0
        self.id_to_body: dict[str, dict] = {}
        self.children: dict[str, list[str]] = defaultdict(list)
        self.seen: set[str] = set()
        self.pending: set[str] = set()

    def reset(self):
        log.info("检测到文件重写，重置状态")
        self.offset = 0
        self.size = 0
        self.id_to_body.clear()
        self.children.clear()
        self.pending.clear()


_file_states: dict[str, FileState] = {}
_state_lock = threading.Lock()
_states_lock = threading.Lock()
_STATE_FILE = Path(os.environ.get("BRIDGE_STATE_FILE", "/tmp/langfuse_bridge_offsets.json"))


def _load_offsets() -> dict[str, int]:
    try:
        if _STATE_FILE.exists():
            return json.loads(_STATE_FILE.read_text())
    except Exception:
        pass
    return {}


def _save_offsets():
    try:
        with _states_lock:
            data = {fp: s.offset for fp, s in _file_states.items()}
        _STATE_FILE.write_text(json.dumps(data))
    except Exception as e:
        log.warning(f"保存 offset 失败: {e}")


def get_file_state(filepath: str) -> FileState:
    with _states_lock:
        if filepath not in _file_states:
            _file_states[filepath] = FileState()
        return _file_states[filepath]


# ── session log 解析 ──────────────────────────────────────────────────────────


def extract_text(content: list) -> str:
    texts = []
    for c in content:
        if c.get("type") == "text":
            text = c.get("text", "").strip()
            text = re.sub(r"^\[\[.*?\]\]\s*", "", text)
            if text:
                texts.append(text)
    return "\n".join(texts)


def extract_feishu_id(content: list) -> str | None:
    for c in content:
        if c.get("type") == "text":
            m = FEISHU_MSG_ID_RE.search(c.get("text", ""))
            if m:
                return m.group(1)
    return None


def extract_user_info(content: list) -> dict:
    for c in content:
        if c.get("type") != "text":
            continue
        raw = c.get("text", "")
        meta = {}
        m = re.search(r"Conversation info.*?```json\s*(\{.*?\})\s*```", raw, re.DOTALL)
        if m:
            try:
                meta = json.loads(m.group(1))
            except Exception:
                pass
        text = raw
        text = re.sub(r"[^\n]*\n```[^\n]*\n.*?```\s*", "", text, flags=re.DOTALL)
        text = re.sub(r"\[message_id:[^\]]*\]\s*", "", text)
        text = re.sub(r"^[^:：\n]+[:：]\s*", "", text.strip())
        return {
            "text":       text.strip(),
            "sender":     meta.get("sender", ""),
            "sender_id":  meta.get("sender_id", ""),
            "message_id": meta.get("message_id", ""),
            "timestamp":  meta.get("timestamp", ""),
        }
    return {"text": "", "sender": "", "sender_id": "", "message_id": "", "timestamp": ""}


def find_assistant_info(state: FileState, node_id: str) -> dict:
    """找最终的 assistant 文本回复（stop=stop 那条）。"""
    visited: set[str] = set()
    queue = list(state.children.get(node_id, []))
    while queue:
        cid = queue.pop(0)
        if cid in visited:
            continue
        visited.add(cid)
        body = state.id_to_body.get(cid)
        if not body:
            continue
        msg  = body["message"]
        role = msg.get("role", "")
        if role == "assistant":
            text = extract_text(msg.get("content", []))
            if text and msg.get("stopReason") == "stop":
                usage_raw = msg.get("usage", {})
                cost_raw  = usage_raw.get("cost", {})
                return {
                    "text":     text,
                    "model":    msg.get("model", ""),
                    "provider": msg.get("provider", ""),
                    "usage": {
                        "input_tokens":       usage_raw.get("input", 0),
                        "output_tokens":      usage_raw.get("output", 0),
                        "cache_read_tokens":  usage_raw.get("cacheRead", 0),
                        "cache_write_tokens": usage_raw.get("cacheWrite", 0),
                        "total_tokens":       usage_raw.get("totalTokens", 0),
                        "total_cost":         round(cost_raw.get("total", 0), 8),
                    },
                    "stop_reason": msg.get("stopReason", ""),
                }
            queue.extend(state.children.get(cid, []))
        elif role in ("toolResult", "user"):
            queue.extend(state.children.get(cid, []))

    # fallback：扫描所有已知节点
    node_ts = state.id_to_body.get(node_id, {}).get("timestamp", "")
    best = None
    best_ts = ""
    for nid, body in state.id_to_body.items():
        msg  = body.get("message", {})
        role = msg.get("role", "")
        if role != "assistant":
            continue
        if msg.get("stopReason") != "stop":
            continue
        text = extract_text(msg.get("content", []))
        if not text:
            continue
        ts = body.get("timestamp", "")
        if node_ts and ts < node_ts:
            continue
        if ts > best_ts:
            best_ts = ts
            best    = msg

    if best:
        usage_raw = best.get("usage", {})
        cost_raw  = usage_raw.get("cost", {})
        return {
            "text":     extract_text(best.get("content", [])),
            "model":    best.get("model", ""),
            "provider": best.get("provider", ""),
            "usage": {
                "input_tokens":       usage_raw.get("input", 0),
                "output_tokens":      usage_raw.get("output", 0),
                "cache_read_tokens":  usage_raw.get("cacheRead", 0),
                "cache_write_tokens": usage_raw.get("cacheWrite", 0),
                "total_tokens":       usage_raw.get("totalTokens", 0),
                "total_cost":         round(cost_raw.get("total", 0), 8),
            },
            "stop_reason": best.get("stopReason", ""),
        }

    return {}


def read_new_lines(filepath: str, state: FileState) -> list[str]:
    try:
        current_size = os.path.getsize(filepath)
    except OSError:
        return []
    if current_size < state.size:
        state.reset()
    if current_size == state.offset:
        return []
    try:
        with open(filepath, "r", encoding="utf-8") as f:
            f.seek(state.offset)
            new_content = f.read()
            new_offset  = f.tell()
    except OSError as e:
        log.error(f"读取文件失败 {filepath}: {e}")
        return []
    state.offset = new_offset
    state.size   = current_size
    _save_offsets()
    lines = new_content.split("\n")
    if new_content and not new_content.endswith("\n"):
        last_newline = new_content.rfind("\n")
        if last_newline >= 0:
            state.offset = state.offset - len(new_content) + last_newline + 1
            lines = lines[:-1]
        else:
            state.offset = state.offset - len(new_content)
            return []
    return [line for line in lines if line.strip()]


def process_new_lines(filepath: str, new_lines: list[str], state: FileState) -> list[dict]:
    new_user_ids = []
    for line in new_lines:
        try:
            obj = json.loads(line)
        except Exception:
            continue
        if obj.get("type") != "message":
            continue
        bid = obj.get("id")
        pid = obj.get("parentId")
        if not bid:
            continue
        is_new_user = (
            obj["message"].get("role") == "user"
            and bid not in state.id_to_body
        )
        state.id_to_body[bid] = obj
        if pid and bid not in state.children.get(pid, []):
            state.children[pid].append(bid)
        if is_new_user:
            new_user_ids.append(bid)
            state.pending.add(bid)

        msg = obj.get("message", {})
        if msg.get("role") == "toolResult" and msg.get("toolName") == "sessions_spawn":
            result_text = next(
                (c.get("text", "") for c in msg.get("content", []) if c.get("type") == "text"), ""
            )
            if result_text:
                try:
                    result_json = json.loads(result_text)
                    child_key = result_json.get("childSessionKey", "")
                    if child_key:
                        child_sid = child_key.split(":")[-1]
                        with _child_parent_lock:
                            if child_sid not in _child_parent_map:
                                _child_parent_map[child_sid] = {
                                    "parent_trace_id": "",
                                    "parent_span_id":  "",
                                    "pending":         True,
                                    "registered_at":   obj.get("timestamp", ""),
                                }
                                log.info(f"[child_map] 预注册子 session: {child_sid[:8]}")
                except Exception:
                    pass

    candidate_ids = list(set(new_user_ids) | state.pending)
    results = []
    for uid in candidate_ids:
        body = state.id_to_body.get(uid)
        if not body:
            continue
        msg_content = body["message"].get("content", [])
        feishu_id   = extract_feishu_id(msg_content)
        if not feishu_id or feishu_id in state.seen:
            state.pending.discard(uid)
            continue
        user_info      = extract_user_info(msg_content)
        user_text      = user_info.get("text", "")
        assistant_info = find_assistant_info(state, uid)
        assistant_text = assistant_info.get("text", "")
        if user_text and assistant_text:
            turns = parse_conversation_turns(state, uid)
            state.seen.add(feishu_id)
            state.pending.discard(uid)
            results.append({
                "feishu_message_id": feishu_id,
                "user_info":         user_info,
                "assistant_info":    assistant_info,
                "turns":             turns,
                "msg_timestamp":     body.get("timestamp", ""),
                "source_filepath":   filepath,
            })
        elif user_text and not assistant_text:
            log.info(f"[pending] 等待 assistant 回复: {feishu_id}")
    return results


def is_subagent_session(lines: list[str]) -> bool:
    """判断是否是 sessions_spawn 启动的子 session"""
    for line in lines:
        try:
            obj = json.loads(line)
            if obj.get("type") == "message" and obj["message"].get("role") == "user":
                content = obj["message"].get("content", [])
                for c in content:
                    if c.get("type") == "text" and "[Subagent Context]" in c.get("text", ""):
                        return True
                return False
        except Exception:
            continue
    return False


def process_subagent_session(filepath: str, state: FileState, new_lines: list[str]):
    """处理 sessions_spawn 启动的子 session"""
    session_id  = Path(filepath).stem
    pending_key = f"__subagent__{session_id}"
    if session_id in state.seen:
        return

    if pending_key in state.pending:
        try:
            with open(filepath, "r", encoding="utf-8") as fh:
                new_lines = [l for l in fh.read().split("\n") if l.strip()]
        except OSError:
            return

    for line in new_lines:
        try:
            obj = json.loads(line)
            if obj.get("type") != "message":
                continue
            bid = obj.get("id")
            pid = obj.get("parentId")
            if not bid:
                continue
            state.id_to_body[bid] = obj
            if pid and bid not in state.children.get(pid, []):
                state.children[pid].append(bid)
        except Exception:
            continue

    task_text = ""
    user_node_id = None
    for line in new_lines:
        try:
            obj = json.loads(line)
            if obj.get("type") == "message" and obj["message"].get("role") == "user":
                content = obj["message"].get("content", [])
                for c in content:
                    if c.get("type") == "text":
                        text = c.get("text", "")
                        text = re.sub(r"^\[.*?\]\s*", "", text).strip()
                        if text:
                            task_text = text
                            user_node_id = obj.get("id")
                            break
                if task_text:
                    break
        except Exception:
            continue

    if not task_text or not user_node_id:
        return

    assistant_info = find_assistant_info(state, user_node_id)
    if not assistant_info.get("text"):
        state.pending.add(f"__subagent__{session_id}")
        log.info(f"[subagent] 等待子 session 完成: {session_id[:8]}")
        return

    state.pending.discard(f"__subagent__{session_id}")
    turns = parse_conversation_turns(state, user_node_id)
    log.info(f"[subagent] 子 session 完成: {session_id[:8]} turns={len(turns)}")

    # 时间戳匹配父 session
    child_key_in_map = None
    session_create_ts = ""
    for line in (new_lines or []):
        try:
            obj = json.loads(line)
            if obj.get("type") == "session":
                session_create_ts = obj.get("timestamp", "")
                break
        except Exception:
            continue
    if not session_create_ts:
        try:
            with open(filepath, "r", encoding="utf-8") as fh:
                for line in fh:
                    try:
                        obj = json.loads(line.strip())
                        if obj.get("type") == "session":
                            session_create_ts = obj.get("timestamp", "")
                            break
                    except Exception:
                        continue
        except OSError:
            pass

    if session_create_ts:
        try:
            ts_dt = datetime.fromisoformat(session_create_ts.replace("Z", "+00:00"))
            best_delta = None
            with _child_parent_lock:
                for key, info in _child_parent_map.items():
                    if key == session_id:
                        continue
                    reg_ts = info.get("registered_at", "")
                    if not reg_ts:
                        continue
                    try:
                        reg_dt = datetime.fromisoformat(reg_ts.replace("Z", "+00:00"))
                        delta = abs((ts_dt - reg_dt).total_seconds())
                        if delta <= 2.0 and (best_delta is None or delta < best_delta):
                            best_delta = delta
                            child_key_in_map = key
                    except Exception:
                        continue
                if child_key_in_map:
                    if session_id not in _child_parent_map:
                        _child_parent_map[session_id] = {"alias_of": child_key_in_map}
                        log.info(f"[child_map] 时间戳关联: {session_id[:8]} <- {child_key_in_map[:8]} delta={best_delta:.3f}s")
        except Exception as e:
            log.warning(f"[child_map] 时间戳匹配失败: {e}")

    parent_trace_id = ""
    parent_span_id  = ""
    with _child_parent_lock:
        raw_info = (_child_parent_map.get(session_id)
                    or _child_parent_map.get(child_key_in_map or "", {}))
        if raw_info and "alias_of" in raw_info:
            parent_info = _child_parent_map.get(raw_info["alias_of"], {})
        else:
            parent_info = raw_info

    if parent_info and (parent_info.get("pending") or not parent_info.get("parent_trace_id")):
        state.pending.add(f"__subagent__{session_id}")
        log.info(f"[subagent] 等待父 trace 写入: {session_id[:8]}")
        return
    elif parent_info:
        parent_trace_id = parent_info.get("parent_trace_id", "")
        parent_span_id  = parent_info.get("parent_span_id", "")
        log.info(f"[subagent] 找到父 trace: {parent_trace_id[:8] if parent_trace_id else 'pending'}")
        if not parent_trace_id:
            state.pending.add(f"__subagent__{session_id}")
            log.info(f"[subagent] 等待父 trace 写入: {session_id[:8]}")
            return
    else:
        log.info(f"[subagent] 未找到父 trace，作为独立 trace 写入")

    state.seen.add(session_id)
    enqueue_subagent(session_id, task_text, assistant_info, turns, filepath,
                     parent_trace_id=parent_trace_id, parent_span_id=parent_span_id)


def enqueue_subagent(session_id: str, task_text: str, assistant_info: dict,
                     turns: list[dict], source_filepath: str,
                     parent_trace_id: str = "", parent_span_id: str = ""):
    """将子 session 作为独立 trace 入队写入 Langfuse"""
    with _lock:
        if session_id in _done:
            return
        for t in _queue:
            if t.feishu_id == session_id:
                return
        task = MergeTask(
            feishu_id       = session_id,
            user_info       = {"text": task_text, "sender": "subagent", "sender_id": "", "message_id": session_id, "timestamp": ""},
            assistant_info  = assistant_info,
            turns           = turns,
            msg_timestamp   = "",
            source_filepath = source_filepath,
        )
        task.is_subagent     = True
        task.parent_trace_id = parent_trace_id
        task.parent_span_id  = parent_span_id
        _queue.append(task)
        log.info(f"[subagent] 入队: {session_id[:8]} parent={parent_trace_id[:8] if parent_trace_id else 'none'} task={task_text[:50]!r}")


def process_file(filepath: str):
    state     = get_file_state(filepath)
    new_lines = read_new_lines(filepath, state)
    if not new_lines:
        return

    if is_subagent_session(new_lines):
        process_subagent_session(filepath, state, new_lines)
        return

    pairs = process_new_lines(filepath, new_lines, state)
    for pair in pairs:
        enqueue(
            pair["feishu_message_id"],
            pair["user_info"],
            pair["assistant_info"],
            pair["turns"],
            pair["msg_timestamp"],
            pair["source_filepath"],
        )


# ── 任务队列 ──────────────────────────────────────────────────────────────────


class MergeTask:
    def __init__(self, feishu_id, user_info, assistant_info, turns, msg_timestamp, source_filepath):
        self.feishu_id       = feishu_id
        self.user_info       = user_info
        self.assistant_info  = assistant_info
        self.turns           = turns
        self.msg_timestamp   = msg_timestamp
        self.source_filepath = source_filepath
        self.attempt         = 0
        self.next_at         = time.time()
        self.is_subagent     = False
        self.parent_trace_id = ""
        self.parent_span_id  = ""


_queue: list[MergeTask] = []
_lock:  threading.Lock  = threading.Lock()
_done:  set[str]        = set()


def enqueue(feishu_id, user_info, assistant_info, turns, msg_timestamp, source_filepath):
    with _lock:
        if feishu_id in _done:
            return
        for t in _queue:
            if t.feishu_id == feishu_id:
                return
        _queue.append(MergeTask(feishu_id, user_info, assistant_info, turns, msg_timestamp, source_filepath))
        log.info(
            f"[enqueue] 📥 入队: {feishu_id} turns={len(turns)} "
            f"model={assistant_info.get('model', 'n/a')} "
            f"input={user_info.get('text','')[:60]!r} "
            f"source={Path(source_filepath).name}"
        )


def ingest_subagent_to_langfuse(task: "MergeTask") -> bool:
    """子 session 直接写入 Langfuse"""
    session_id       = task.feishu_id
    parent_trace_id  = getattr(task, "parent_trace_id", "")
    parent_span_id   = getattr(task, "parent_span_id", "")
    now_ts           = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%f")[:23] + "Z"
    prompt_meta      = get_prompt_meta_for_session(task.source_filepath)

    start_time = (task.turns[0].get("start_time") if task.turns else "") or now_ts
    end_time   = (task.turns[-1].get("end_time")   if task.turns else "") or now_ts
    model      = (task.turns[0].get("model")       if task.turns else "") or ""
    provider   = (task.turns[0].get("provider")    if task.turns else "") or ""

    input_obj = {
        "text": task.user_info.get("text", ""),
        "type": "subagent_task",
    }
    output_obj = {
        "text":        task.assistant_info.get("text", ""),
        "model":       model,
        "stop_reason": task.assistant_info.get("stop_reason", ""),
    }

    if parent_trace_id:
        effective_trace_id = normalize_trace_id(parent_trace_id)
        log.info(f"[subagent] 挂载到父 trace: {effective_trace_id[:12]}")
    else:
        effective_trace_id = normalize_trace_id(session_id)
        log.info(f"[subagent] 独立 trace: {effective_trace_id[:12]}")

    processed_info = {
        "trace_id":    effective_trace_id,
        "timestamp":   start_time,
        "end_time":    end_time,
        "environment": "default",
        "user_id":     "",
        "channel":     "subagent",
        "chat_id":     "",
        "session_key": session_id,
        "resource":    {},
    }
    usage_info = {
        "session_id":         session_id,
        "model":              model,
        "provider":           provider,
        "input_tokens":       sum(t.get("input_tokens", 0) for t in task.turns),
        "output_tokens":      sum(t.get("output_tokens", 0) for t in task.turns),
        "cache_read_tokens":  sum(t.get("cache_read_tokens", 0) for t in task.turns),
        "cache_write_tokens": sum(t.get("cache_write_tokens", 0) for t in task.turns),
        "total_tokens":       (task.turns[-1].get("total_tokens", 0) if task.turns else 0),
    }

    ok = ingest_to_langfuse(
        processed_info, usage_info,
        input_obj, output_obj,
        prompt_meta,
        task.turns,
        trace_name="openclaw.subagent.task",
        skip_trace_create=bool(parent_trace_id),
        parent_span_id=parent_span_id,
    )

    if ok:
        with _child_parent_lock:
            _child_parent_map.pop(session_id, None)

    return ok


def _scan_parent_sessions_for_child_map():
    """主动扫描父 session 文件，补充未注册的 child_session_id"""
    with _state_lock:
        states_snapshot = list(_file_states.items())

    for filepath, state in states_snapshot:
        try:
            with open(filepath, "r", encoding="utf-8") as fh:
                first_lines = fh.read(2000)
        except OSError:
            continue
        if "[Subagent Context]" in first_lines:
            continue

        scan_offset = state.offset if state else 0

        try:
            with open(filepath, "r", encoding="utf-8") as fh:
                fh.seek(0)
                content_to_scan = fh.read(scan_offset) if scan_offset > 0 else fh.read()
            for line in content_to_scan.split("\n"):
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                    if obj.get("type") != "message":
                        continue
                    msg = obj.get("message", {})
                    if msg.get("role") != "toolResult" or msg.get("toolName") != "sessions_spawn":
                        continue
                    result_text = next(
                        (c.get("text", "") for c in msg.get("content", []) if c.get("type") == "text"), ""
                    )
                    if not result_text:
                        continue
                    result_json = json.loads(result_text)
                    child_key = result_json.get("childSessionKey", "")
                    if not child_key:
                        continue
                    child_sid = child_key.split(":")[-1]
                    event_ts = obj.get("timestamp", "")
                    if event_ts:
                        try:
                            ts_dt = datetime.fromisoformat(event_ts.replace("Z", "+00:00"))
                            age_seconds = (datetime.now(timezone.utc) - ts_dt).total_seconds()
                            if age_seconds > 300:
                                continue
                        except Exception:
                            pass
                    with _child_parent_lock:
                        if child_sid not in _child_parent_map:
                            _child_parent_map[child_sid] = {
                                "parent_trace_id": "",
                                "parent_span_id":  "",
                                "pending":         True,
                                "registered_at":   event_ts,
                            }
                            log.info(f"[child_map] 补充预注册: {child_sid[:8]}")
                except Exception:
                    continue
        except OSError:
            continue


def _retry_pending_subagents():
    """主动重试未完成的子 session"""
    _scan_parent_sessions_for_child_map()

    with _state_lock:
        states_snapshot = list(_file_states.items())

    for filepath, state in states_snapshot:
        pending_subagents = [
            k for k in list(state.pending)
            if k.startswith("__subagent__")
        ]
        if pending_subagents:
            log.info(f"[subagent] 主动重试: {filepath[-30:]} pending={len(pending_subagents)}")
            try:
                process_subagent_session(filepath, state, [])
            except Exception as e:
                log.error(f"[subagent] 重试异常: {e}")


def _build_usage_from_turns(turns: list[dict], assistant_info: dict, processed_info: dict) -> dict:
    """
    ★ v2.2: 从 session jsonl 的 turns 数据构建 usage_info，不依赖 OTel usage span。
    session jsonl 比 usage span 更完整：有 cost、stopReason、每轮分别统计。
    """
    if turns:
        # 从最后一轮取汇总数据
        last_turn = turns[-1]
        model    = last_turn.get("model", "")
        provider = last_turn.get("provider", "")
        total    = last_turn.get("total_tokens", 0)
        # 所有轮次的 input/output 累加
        total_in  = sum(t.get("input_tokens", 0) for t in turns)
        total_out = sum(t.get("output_tokens", 0) for t in turns)
        total_cr  = sum(t.get("cache_read_tokens", 0) for t in turns)
        total_cw  = sum(t.get("cache_write_tokens", 0) for t in turns)
    else:
        # fallback: 从 assistant_info 获取
        usage = assistant_info.get("usage", {})
        model    = assistant_info.get("model", "")
        provider = assistant_info.get("provider", "")
        total_in  = usage.get("input_tokens", 0)
        total_out = usage.get("output_tokens", 0)
        total_cr  = usage.get("cache_read_tokens", 0)
        total_cw  = usage.get("cache_write_tokens", 0)
        total     = usage.get("total_tokens", 0)

    # session_id 从 processed_info 的 session_key 提取
    session_key = processed_info.get("session_key", "")
    # session_key 格式: agent:feishu-bot-1:feishu:direct:ou_xxx
    # sessionId 在 session jsonl 的文件名里，这里用 session_key 作为 fallback
    session_id = session_key

    usage_info = {
        "session_id":         session_id,
        "model":              model,
        "provider":           provider,
        "input_tokens":       total_in,
        "output_tokens":      total_out,
        "cache_read_tokens":  total_cr,
        "cache_write_tokens": total_cw,
        "total_tokens":       total,
    }

    log.debug(
        f"[usage] 从 turns 构建: model={model} provider={provider} "
        f"in={total_in} out={total_out} cr={total_cr} cw={total_cw} total={total}"
    )

    return usage_info


def worker():
    last_subagent_retry = 0.0
    while True:
        now = time.time()

        if now - last_subagent_retry >= 5:
            _retry_pending_subagents()
            last_subagent_retry = now

        with _lock:
            ready = [t for t in _queue if t.next_at <= now]

        for task in ready:
            if getattr(task, "is_subagent", False):
                ok = ingest_subagent_to_langfuse(task)
                if ok:
                    with _lock:
                        _done.add(task.feishu_id)
                        _queue.remove(task)
                else:
                    task.attempt += 1
                    if task.attempt >= MAX_RETRIES:
                        log.error(f"[worker] 放弃子 session: {task.feishu_id}")
                        with _lock:
                            _queue.remove(task)
                    else:
                        task.next_at = now + get_retry_delay(task.attempt)
                continue

            with _span_lock:
                span_data      = _span_cache.get(task.feishu_id, {})
                processed_info = span_data.get("processed")

            if processed_info is None:
                task.attempt += 1
                delay = get_retry_delay(task.attempt)
                if task.attempt <= 3 or task.attempt % 10 == 0:
                    log.info(
                        f"[worker] ⏳ 等待 processed span: {task.feishu_id} "
                        f"attempt={task.attempt}/{MAX_RETRIES} next_retry={delay}s"
                    )
                if task.attempt >= MAX_RETRIES:
                    log.warning(f"[worker] ❌ 放弃（processed 未到达）: {task.feishu_id}")
                    with _lock:
                        _queue.remove(task)
                else:
                    task.next_at = now + delay
                continue

            # ★ v2.2: 不再等待 usage span，从 session jsonl 的 turns 构建 usage_info
            # turns 里已经有完整的 model、provider、tokens、cost 数据
            usage_info = _build_usage_from_turns(task.turns, task.assistant_info, processed_info)
            log.info(
                f"[worker] 📦 准备写入: {task.feishu_id} "
                f"model={usage_info.get('model', 'n/a')} "
                f"provider={usage_info.get('provider', 'n/a')} "
                f"tokens={usage_info.get('total_tokens', 0)} "
                f"turns={len(task.turns)}"
            )

            prompt_meta = get_prompt_meta_for_session(task.source_filepath)

            input_obj = {
                "text":       task.user_info.get("text", ""),
                "sender":     task.user_info.get("sender", ""),
                "sender_id":  task.user_info.get("sender_id", ""),
                "message_id": task.feishu_id,
                "timestamp":  task.user_info.get("timestamp", ""),
                "channel":    processed_info.get("channel", ""),
                "chat_id":    processed_info.get("chat_id", ""),
            }
            output_obj = {
                "text":        task.assistant_info.get("text", ""),
                "model":       task.assistant_info.get("model", ""),
                "provider":    task.assistant_info.get("provider", ""),
                "usage":       task.assistant_info.get("usage", {}),
                "stop_reason": task.assistant_info.get("stop_reason", ""),
            }

            log.info(
                f"[worker] 🚀 开始写入 Langfuse: {task.feishu_id} "
                f"trace={processed_info.get('trace_id', 'n/a')[:12]} "
                f"input={task.user_info.get('text', '')[:60]!r}"
            )

            ok = ingest_to_langfuse(
                processed_info, usage_info,
                input_obj, output_obj,
                prompt_meta,
                task.turns,
            )

            if ok:
                with _span_lock:
                    _span_cache.pop(task.feishu_id, None)
                with _lock:
                    _done.add(task.feishu_id)
                    _queue.remove(task)
                log.info(f"[worker] 🎉 写入完成: {task.feishu_id}")
            else:
                task.attempt += 1
                if task.attempt >= MAX_RETRIES:
                    log.error(f"[worker] ❌ 放弃（写入持续失败）: {task.feishu_id}")
                    with _lock:
                        _queue.remove(task)
                else:
                    task.next_at = now + get_retry_delay(task.attempt)
                    log.warning(
                        f"[worker] ⚠️ 写入失败，重试: {task.feishu_id} "
                        f"attempt={task.attempt} next_retry={get_retry_delay(task.attempt)}s"
                    )

        time.sleep(1)


# ── 文件监听 ──────────────────────────────────────────────────────────────────

from watchdog.observers.polling import PollingObserver
from watchdog.events import FileSystemEventHandler


class LogHandler(FileSystemEventHandler):
    def on_modified(self, event):
        if not event.is_directory and event.src_path.endswith(".jsonl"):
            process_file(event.src_path)

    def on_created(self, event):
        if not event.is_directory and event.src_path.endswith(".jsonl"):
            process_file(event.src_path)


# ── 主入口 ────────────────────────────────────────────────────────────────────


def main():
    if not PUBLIC_KEY or not SECRET_KEY:
        log.error("未设置 LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY，退出")
        return

    valid_paths = [p for p in SESSIONS_DIRS if p.exists()]
    if not valid_paths:
        log.error("没有有效的 sessions 目录")
        return

    log.info("=" * 60)
    log.info("Bridge v2.3 启动（修复 cost/latency/重复 trace/input 清洗）")
    log.info(f"  Langfuse : {LANGFUSE_HOST}")
    log.info(f"  HTTP     : :{BRIDGE_PORT}")
    for p in valid_paths:
        log.info(f"  Sessions : {p}")
    log.info(f"  Langfuse SDK: {'已初始化' if _lf_client else '❌ 未初始化'}")
    log.info(f"  Public Key : {PUBLIC_KEY[:12]}..." if PUBLIC_KEY else "  Public Key : ❌ 未设置")
    log.info("=" * 60)

    threading.Thread(target=start_http_server, daemon=True).start()
    threading.Thread(target=worker, daemon=True).start()

    saved_offsets = _load_offsets()
    for sessions_path in valid_paths:
        for f in sorted(sessions_path.glob("*.jsonl")):
            fp = str(f)
            state = get_file_state(fp)
            current_size = f.stat().st_size
            if fp in saved_offsets:
                state.offset = min(saved_offsets[fp], current_size)
                state.size   = current_size
            else:
                state.offset = current_size
                state.size   = current_size

    observer = PollingObserver(timeout=1)
    for sessions_path in valid_paths:
        observer.schedule(LogHandler(), str(sessions_path), recursive=False)
        log.info(f"[watchdog] 监听: {sessions_path}")
    observer.start()

    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        observer.stop()
        log.info("Bridge 停止")
    observer.join()


if __name__ == "__main__":
    main()



